{
  "$schema": "../../schemas/application.schema.json",
  "application": "erp",
  "name": "Sektor",
  "description": "erp.application.description",
  "icon": "layout-grid",
  "domains": [
    "item",
    "stock",
    "currency",
    "finance",
    "partner",
    "achats",
    "ventes",
    "chantiers",
    "etudes",
    "rh",
    "hse",
    "marches",
    "approbations"
  ],
  "zones": [
    { "id": "inventory", "label": "zones.inventory", "order": 1 },
    { "id": "finance", "label": "zones.finance", "order": 2 },
    { "id": "commerce", "label": "zones.commerce", "order": 3 },
    { "id": "projects", "label": "zones.projects", "order": 4 },
    { "id": "people", "label": "zones.people", "order": 5 },
    { "id": "compliance", "label": "zones.compliance", "order": 6 },
    { "id": "contracts", "label": "zones.contracts", "order": 7 },
    { "id": "governance", "label": "zones.governance", "order": 8 }
  ],
  "navigation": {
    "domainGroups": [
      {
        "id": "inventory",
        "label": "zones.inventory",
        "icon": "warehouse",
        "zone": "inventory",
        "order": 1,
        "domains": ["item", "stock"]
      },
      {
        "id": "finance",
        "label": "zones.finance",
        "icon": "landmark",
        "zone": "finance",
        "order": 2,
        "domains": ["currency", "finance"]
      },
      {
        "id": "commerce",
        "label": "zones.commerce",
        "icon": "shopping-cart",
        "zone": "commerce",
        "order": 3,
        "domains": ["partner", "achats", "ventes"]
      },
      {
        "id": "projects",
        "label": "zones.projects",
        "icon": "hard-hat",
        "zone": "projects",
        "order": 4,
        "domains": ["chantiers", "etudes"]
      },
      {
        "id": "people",
        "label": "zones.people",
        "icon": "users",
        "zone": "people",
        "order": 5,
        "domains": ["rh"]
      },
      {
        "id": "compliance",
        "label": "zones.compliance",
        "icon": "shield-check",
        "zone": "compliance",
        "order": 6,
        "domains": ["hse"]
      },
      {
        "id": "contracts",
        "label": "zones.contracts",
        "icon": "file-signature",
        "zone": "contracts",
        "order": 7,
        "domains": ["marches"]
      },
      {
        "id": "governance",
        "label": "zones.governance",
        "icon": "check-circle",
        "zone": "governance",
        "order": 8,
        "domains": ["approbations"]
      }
    ]
  },
  "features": {
    "iam": true,
    "subscription": true,
    "app-settings": true,
    "user-settings": true,
    "sysconfig": true,
    "notification": true,
    "doc-manager": true,
    "audit": true,
    "comment": true,
    "workflow": true,
    "tagging": true,
    "doc-extractor": true,
    "llm-provider": true,
    "ai-conversation": true,
    "ai-agent-runtime": true
  },
  "infrastructure": {
    "database": {
      "mode": "app",
      "name": "nafura_erp",
      "schema": "public"
    },
    "objectStorage": {
      "enabled": true,
      "provider": "minio",
      "bucket": "nafura-erp"
    },
    "identity": {
      "enabled": true,
      "realm": "nafura",
      "provider": "keycloak"
    },
    "vault": {
      "enabled": true,
      "provider": "hashicorp-vault",
      "secretsPath": "secret/nafura/erp"
    },
    "search": {
      "enabled": true,
      "provider": "opensearch",
      "index": "nafura-erp-documents"
    }
  },
  "components": {
    "backend": {
      "enabled": true,
      "apiBasePath": "/api",
      "keycloak": {
        "clientId": "erp-backend",
        "name": "ERP Backend",
        "serviceAccountsEnabled": true
      }
    },
    "web": {
      "enabled": true,
      "baseUrl": "https://erp.nafura.local",
      "keycloak": {
        "clientId": "erp-web",
        "name": "ERP Web",
        "publicClient": true,
        "standardFlowEnabled": true
      }
    }
  },
  "settings": {
    "defaultLocale": "en",
    "supportedLocales": [
      "en",
      "fr"
    ],
    "defaultRoute": "dashboard",
    "theme": "nafura-light"
  },
  "defaultTenant": {
    "key": "nafura",
    "name": "Nafura",
    "domains": [
      "item",
      "stock",
      "currency",
      "partner",
      "achats",
      "ventes",
      "chantiers",
      "etudes",
      "rh",
      "hse",
      "marches",
      "approbations"
    ]
  },
  "capabilities": {
    "authorization": {
      "enabled": true
    },
    "userContext": {
      "enabled": true
    },
    "tenancy": {
      "mode": "multi",
      "validateMembership": true
    },
    "tenantAdmin": {
      "enabled": true
    },
    "subscriptions": {
      "enabled": true,
      "scope": "tenant",
      "delivery": "saas"
    },
    "aiConversation": {
      "enabled": true
    },
    "aiAgentRuntime": {
      "enabled": true
    }
  },
  "roleTemplates": [
    {
      "id": "OWNER",
      "name": "Owner",
      "isSystem": true,
      "scope": "app",
      "defaultUser": {
        "email": "owner@erp.local",
        "firstName": "Owner",
        "lastName": "User",
        "password": "ChangeMe@123!",
        "scope": "tenant"
      },
      "permissions": [
        "*"
      ]
    },
    {
      "id": "ADMIN",
      "name": "Administrator",
      "isSystem": true,
      "scope": "app",
      "defaultUser": {
        "email": "admin@erp.local",
        "firstName": "Admin",
        "lastName": "User",
        "password": "ChangeMe@123!",
        "scope": "tenant"
      },
      "permissions": [
        "tenant.*",
        "administration.*",
        "item.*",
        "stock.*",
        "currency.*",
        "finance.*",
        "partner.*",
        "achats.*",
        "ventes.*",
        "chantiers.*",
        "etudes.*",
        "rh.*",
        "hse.*",
        "marches.*",
        "approbations.*",
        "profile:full"
      ]
    },
    {
      "id": "MANAGER",
      "name": "Manager",
      "isSystem": true,
      "scope": "app",
      "defaultUser": {
        "email": "manager@erp.local",
        "firstName": "Manager",
        "lastName": "User",
        "password": "ChangeMe@123!",
        "scope": "tenant"
      },
      "permissions": [
        "tenant.read",
        "tenant.members.read",
        "tenant.roles.read",
        "tenant.settings.read",
        "item.*",
        "stock.*",
        "currency.*",
        "partner.*",
        "achats.read",
        "achats.create",
        "achats.update",
        "achats.kpis.read",
        "achats.analytics.read",
        "ventes.read",
        "ventes.create",
        "ventes.update",
        "ventes.kpis.read",
        "ventes.analytics.read",
        "chantiers.read",
        "chantiers.kpis.read",
        "chantiers.analytics.read",
        "chantiers.pilotage.read",
        "etudes.read",
        "rh.read",
        "rh.kpis.read",
        "rh.analytics.read",
        "hse.read",
        "hse.kpis.read",
        "hse.analytics.read",
        "hse.ppsps.read",
        "hse.ppsps.create",
        "hse.ppsps.update",
        "hse.phs.read",
        "hse.phs.create",
        "hse.epi-dotations.read",
        "hse.epi-dotations.create",
        "hse.epi-dotations.update",
        "hse.duer.read",
        "hse.duer.create",
        "hse.duer.update",
        "hse.visites-medicales.read",
        "hse.visites-medicales.create",
        "hse.visites-medicales.update",
        "hse.registres-legaux.read",
        "hse.registres-legaux.create",
        "hse.registres-legaux.update",
        "finance.kpis.read",
        "finance.analytics.read",
        "marches.read",
        "marches.kpis.read",
        "marches.facture.read",
        "marches.facture.create",
        "marches.facture.update",
        "marches.dgd.read",
        "marches.dgd.create",
        "marches.dgd.update",
        "marches.revision-prix.read",
        "marches.revision-prix.update",
        "marches.penalite.read",
        "marches.penalite.create",
        "marches.penalite.update",
        "marches.os.read",
        "marches.os.create",
        "marches.os.update",
        "marches.reception.read",
        "marches.reception.create",
        "marches.reception.update",
        "approbations.read",
        "approbations.workflows.read",
        "approbations.workflows.create",
        "approbations.workflows.update",
        "approbations.requests.read",
        "approbations.requests.create",
        "approbations.requests.update",
        "approbations.delegations.read",
        "approbations.delegations.create",
        "approbations.delegations.update",
        "approbations.matrice-pouvoirs.read",
        "approbations.matrice-pouvoirs.create",
        "approbations.matrice-pouvoirs.update",
        "profile:no-delete"
      ]
    },
    {
      "id": "MEMBER",
      "name": "Member",
      "isSystem": true,
      "scope": "app",
      "defaultUser": {
        "email": "member@erp.local",
        "firstName": "Member",
        "lastName": "User",
        "password": "ChangeMe@123!",
        "scope": "tenant"
      },
      "permissions": [
        "tenant.read",
        "item.read",
        "stock.read",
        "currency.read",
        "partner.read",
        "profile:read-update"
      ]
    },
    {
      "id": "VIEWER",
      "name": "Viewer",
      "isSystem": true,
      "scope": "app",
      "defaultUser": {
        "email": "viewer@erp.local",
        "firstName": "Viewer",
        "lastName": "User",
        "password": "ChangeMe@123!",
        "scope": "tenant"
      },
      "permissions": [
        "tenant.read",
        "item.read",
        "stock.read",
        "currency.read",
        "partner.read",
        "profile:read-only"
      ]
    },
    {
      "id": "BTP_DG",
      "name": "BTP — Direction générale",
      "isSystem": false,
      "scope": "app",
      "permissions": [
        "*"
      ]
    },
    {
      "id": "BTP_DAF",
      "name": "BTP — DAF",
      "isSystem": false,
      "scope": "app",
      "permissions": [
        "currency.*",
        "partner.*",
        "achats.*",
        "ventes.*",
        "marches.*",
        "item.read",
        "stock.read",
        "chantiers.read",
        "etudes.read",
        "rh.read",
        "hse.read",
        "approbations.read"
      ]
    },
    {
      "id": "BTP_CONDUCTEUR_TRAVAUX",
      "name": "BTP — Conducteur de travaux",
      "isSystem": false,
      "scope": "app",
      "permissions": [
        "chantiers.*",
        "rh.pointage.*",
        "rh.read",
        "hse.*",
        "achats.read",
        "ventes.read",
        "partner.read",
        "item.read",
        "stock.read"
      ]
    },
    {
      "id": "BTP_CHEF_CHANTIER",
      "name": "BTP — Chef de chantier",
      "isSystem": false,
      "scope": "app",
      "permissions": [
        "chantiers.read",
        "chantiers.avancement.*",
        "chantiers.photos.*",
        "rh.pointage.create",
        "rh.pointage.read",
        "hse.read",
        "hse.incident.create",
        "stock.read",
        "item.read",
        "partner.read",
        "achats.read",
        "ventes.read"
      ]
    }
  ],
  "users": [
    {
      "email": "super.admin@nafuralabs.com",
      "firstName": "Super",
      "lastName": "Admin",
      "password": "ChangeMe@123!",
      "scope": "global",
      "roles": [],
      "keycloakRoles": [
        "SUPER_ADMIN"
      ]
    }
  ]
}
