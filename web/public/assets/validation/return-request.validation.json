{
  "entity": "ReturnRequest",
  "fields": {
    "requestNumber": {
      "required": true,
      "maxLength": 60,
      "unique": true
    },
    "customerId": {
      "required": true
    },
    "reason": {
      "required": true,
      "maxLength": 2000
    },
    "returnType": {
      "required": true,
      "maxLength": 30
    },
    "requestDate": {
      "required": true
    },
    "refundAmount": {
      "min": 0
    },
    "status": {
      "required": true,
      "maxLength": 30
    },
    "notes": {
      "maxLength": 2000
    }
  }
}
