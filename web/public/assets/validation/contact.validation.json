{
  "entity": "Contact",
  "fields": {
    "code": {
      "maxLength": 50
    },
    "name": {
      "required": true,
      "maxLength": 200
    },
    "email": {
      "maxLength": 255,
      "pattern": "^[\\w.-]+@[\\w.-]+\\.\\w{2,}$"
    },
    "phone": {
      "maxLength": 50
    },
    "mobile": {
      "maxLength": 50
    },
    "description": {
      "maxLength": 2000
    }
  }
}
