{
  "entity": "ApCreditNote",
  "fields": {
    "creditNoteNumber": {
      "required": true,
      "maxLength": 60,
      "unique": true
    },
    "vendorId": {
      "required": true
    },
    "creditDate": {
      "required": true
    },
    "amount": {
      "required": true,
      "min": 0
    },
    "currency": {
      "required": true,
      "maxLength": 10
    },
    "reason": {
      "maxLength": 2000
    },
    "status": {
      "required": true,
      "maxLength": 30
    },
    "notes": {
      "maxLength": 2000
    }
  }
}
