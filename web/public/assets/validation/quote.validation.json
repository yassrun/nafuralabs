{
  "entity": "Quote",
  "fields": {
    "quoteNumber": {
      "required": true,
      "maxLength": 60,
      "unique": true
    },
    "customerId": {
      "required": true
    },
    "quoteDate": {
      "required": true
    },
    "validUntil": {
      "required": true
    },
    "currencyId": {
      "required": true
    },
    "subtotalAmount": {
      "required": true,
      "min": 0
    },
    "discountAmount": {
      "min": 0
    },
    "taxAmount": {
      "min": 0
    },
    "totalAmount": {
      "required": true,
      "min": 0
    },
    "status": {
      "required": true,
      "maxLength": 30
    },
    "notes": {
      "maxLength": 2000
    }
  }
}
