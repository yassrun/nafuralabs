{
  "entity": "PaymentRun",
  "fields": {
    "runNumber": {
      "required": true,
      "maxLength": 60,
      "unique": true
    },
    "paymentMethodId": {
      "required": true
    },
    "bankAccountId": {
      "required": true
    },
    "plannedDate": {
      "required": true
    },
    "currencyId": {
      "required": true
    },
    "invoiceCount": {
      "required": true,
      "min": 0
    },
    "vendorCount": {
      "required": true,
      "min": 0
    },
    "totalAmount": {
      "required": true,
      "min": 0
    },
    "status": {
      "required": true,
      "maxLength": 30
    }
  }
}
