{
  "entity": "Partner",
  "fields": {
    "code": {
      "maxLength": 50,
      "unique": true
    },
    "name": {
      "required": true,
      "maxLength": 255
    },
    "taxId": {
      "maxLength": 50
    },
    "email": {
      "maxLength": 255,
      "pattern": "^[\\w.-]+@[\\w.-]+\\.\\w{2,}$"
    },
    "phone": {
      "maxLength": 30
    },
    "description": {
      "maxLength": 2000
    }
  }
}
