{
  "entity": "FiscalPeriod",
  "fields": {
    "code": {
      "required": true,
      "maxLength": 50,
      "unique": true
    },
    "fiscalYearId": {
      "required": true
    },
    "name": {
      "required": true,
      "maxLength": 100
    },
    "periodNumber": {
      "required": true,
      "min": 1,
      "max": 16
    },
    "startDate": {
      "required": true
    },
    "endDate": {
      "required": true
    },
    "status": {
      "required": true,
      "maxLength": 30
    }
  }
}
