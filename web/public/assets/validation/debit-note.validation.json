{
  "entity": "DebitNote",
  "fields": {
    "noteNumber": {
      "required": true,
      "maxLength": 60,
      "unique": true
    },
    "vendorId": {
      "required": true
    },
    "noteDate": {
      "required": true
    },
    "amount": {
      "required": true,
      "min": 0
    },
    "currencyId": {
      "required": true
    },
    "reason": {
      "maxLength": 2000
    },
    "status": {
      "required": true,
      "maxLength": 30
    }
  }
}
